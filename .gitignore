# macOS
.DS_Store

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Claude Code — user-specific local settings (machine-specific overrides;
# project-level .claude/settings.json IS committed, only .local is private)
.claude/settings.local.json

# Local environment / secrets
.env
.env.local
.env.*.local

# Backup / temp
*.bak
*.tmp

# Other OS noise
Thumbs.db
desktop.ini

# Playwright MCP session artifacts (page snapshots, console logs)
.playwright-mcp/

# Engineering metrics — latest.* is volatile output of scripts/metrics/collect.sh,
# regenerated on every run. history/ is the persisted snapshot trail and IS committed.
docs/metrics/latest.md
docs/metrics/latest.html

# Stakeholder observability dashboard — regenerated on every run of
# scripts/observability/render-dashboard.sh. Derived from committed sources
# (timeline.log, orchestrator-state, goals/), so the snapshot isn't tracked.
docs/dashboard/index.html
